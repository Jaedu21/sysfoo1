# Archivo de configuración de variables de entorno para Jenkins
# Copiar a .env y personalizar según necesidades

# Secreto del agente Jenkins (generar con: openssl rand -hex 32)
JENKINS_AGENT_SECRET=tu_secreto_aqui

# Configuración de Java
JAVA_OPTS=-Xmx2048m -Xms1024m

# Configuración de Jenkins
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=admin123

# Configuración de red
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# Timezone
TZ=America/Bogota
